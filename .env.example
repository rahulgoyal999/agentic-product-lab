# Copy to .env and fill in. .env is gitignored.

# Leave provider unset (or "stub") to run without any API key.
# Set to "openai" to use a real OpenAI-compatible endpoint.
AGENT_PROVIDER=stub

# Only needed when AGENT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: point at any OpenAI-compatible endpoint
OPENAI_BASE_URL=
